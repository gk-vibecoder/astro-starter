---
import { getCollection } from 'astro:content';
import IndexLayout from '@/layouts/IndexLayout.astro';
import { Badge } from '@/components/ui/badge';
import { AnimatedSection } from '@/components/ui/AnimatedSection';
import { seo } from '@/config/seo';
import { getLangFromUrl } from '@/i18n/utils';
import { normalizeId } from '@/lib/related';

const lang = getLangFromUrl(Astro.url);

const posts = (await getCollection('blog', (p) => !p.data.draft && p.data.lang === 'en'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<IndexLayout
  title={seo.blog.title}
  description={seo.blog.description}
  eyebrow="Blog"
  heroTitle="Insights & updates"
  heroDescription="Stories, product updates, and thinking from the Acme team."
  alternateHref="/sv/blog"
>
  <section class="mx-auto max-w-3xl px-6 py-16">
    {posts.length === 0 && (
      <AnimatedSection client:visible>
        <p class="text-muted-foreground">No posts yet — check back soon.</p>
      </AnimatedSection>
    )}

    <div class="space-y-8">
      {posts.map((post) => (
        <AnimatedSection client:visible>
          <article class="group">
            <a href={`/blog/${normalizeId(post.id)}`} class="block">
              <div class="flex items-center gap-3 mb-2">
                <time
                  datetime={post.data.pubDate.toISOString()}
                  class="text-sm text-muted-foreground"
                >
                  {post.data.pubDate.toLocaleDateString('en-GB', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>
                {post.data.tags?.slice(0, 2).map((tag) => (
                  <Badge variant="secondary">{tag}</Badge>
                ))}
              </div>
              <h2 class="text-xl font-semibold text-foreground group-hover:text-foreground/80 transition-colors">
                {post.data.title}
              </h2>
              <p class="mt-2 text-muted-foreground leading-relaxed">
                {post.data.description}
              </p>
              <span class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-foreground">
                Read more
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
              </span>
            </a>
            <div class="mt-8 border-b border-border" />
          </article>
        </AnimatedSection>
      ))}
    </div>
  </section>
</IndexLayout>
