---
import { AnimatedSection } from '@/components/ui/AnimatedSection';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const integrations = [
  { name: 'Stripe', sub: 'Payments & billing' },
  { name: 'Salesforce', sub: 'CRM & sales' },
  { name: 'HubSpot', sub: 'Marketing & CRM' },
  { name: 'Slack', sub: 'Team communication' },
  { name: 'Zapier', sub: 'Workflow automation' },
  { name: 'GitHub', sub: 'Code & DevOps' },
  { name: 'Google', sub: 'Workspace & analytics' },
];
---

<section id="integrations" class="border-y border-border bg-muted/30 py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <AnimatedSection client:visible>
        <p class="text-xs font-semibold tracking-widest uppercase text-muted-foreground mb-4">{t.integrations.label}</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-foreground">
          {t.integrations.headline}
        </h2>
        <p class="mt-4 text-lg text-muted-foreground leading-relaxed">
          {t.integrations.description}
        </p>
        <p class="mt-3 text-sm text-muted-foreground">
          {t.integrations.subtext}
        </p>
      </AnimatedSection>

      <AnimatedSection client:visible delay={0.2} className="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {integrations.map(({ name, sub }) => (
          <div class="rounded-xl border border-border bg-card px-5 py-4 flex items-center gap-3">
            <div class="size-8 rounded-md bg-muted flex items-center justify-center shrink-0">
              <span class="text-xs font-bold text-foreground">{name.slice(0, 2)}</span>
            </div>
            <div class="min-w-0">
              <p class="text-sm font-semibold text-foreground truncate">{name}</p>
              <p class="text-xs text-muted-foreground truncate">{sub}</p>
            </div>
          </div>
        ))}
        <div class="rounded-xl border border-dashed border-border px-5 py-4 flex items-center gap-3">
          <div class="size-8 rounded-md bg-muted flex items-center justify-center shrink-0">
            <span class="text-foreground text-base">+</span>
          </div>
          <p class="text-sm text-muted-foreground">{t.integrations.moreSoon}</p>
        </div>
      </AnimatedSection>
    </div>
  </div>
</section>
