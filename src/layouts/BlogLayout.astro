---
import { SEO } from 'astro-seo';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import '@/styles/globals.css';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  author?: string;
  ogImage?: string;
  slug: string;
}

const { title, description, pubDate, author, ogImage, slug } = Astro.props;

const siteUrl = 'https://acme.com';
const canonicalURL = new URL(`/blog/${slug}`, siteUrl).href;
const image = ogImage ?? `${siteUrl}/og-default.png`;

const organizationSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Acme',
  url: siteUrl,
  logo: `${siteUrl}/favicon.svg`,
  description: 'The Modern Platform Powered by AI',
});

const articleStructuredData = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  author: author
    ? { '@type': 'Person', name: author }
    : { '@type': 'Organization', name: 'Acme' },
  publisher: {
    '@type': 'Organization',
    name: 'Acme',
    url: siteUrl,
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/favicon.svg`,
    },
  },
  url: canonicalURL,
  image,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalURL,
  },
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={title}
      titleTemplate="%s — Acme Blog"
      description={description}
      canonical={canonicalURL}
      openGraph={{
        basic: {
          title,
          type: 'article',
          image,
          url: canonicalURL,
        },
        optional: {
          description,
          siteName: 'Acme',
        },
        article: {
          publishedTime: pubDate.toISOString(),
          authors: author ? [author] : [],
        },
      }}
      twitter={{
        card: 'summary_large_image',
        title,
        description,
        image,
      }}
    />

    <script type="application/ld+json" set:html={organizationSchema} />
    <script type="application/ld+json" set:html={articleStructuredData} />
  </head>

  <body>
    <Header />
    <main class="mx-auto max-w-3xl px-6 py-16 md:py-24">
      <article>
        <header class="mb-10">
          <time
            datetime={pubDate.toISOString()}
            class="text-sm text-muted-foreground"
          >
            {pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
          <h1 class="mt-3 text-4xl font-bold tracking-tight text-foreground">
            {title}
          </h1>
          <p class="mt-4 text-lg text-muted-foreground">{description}</p>
          {author && (
            <p class="mt-4 text-sm text-muted-foreground">
              By <span class="font-medium text-foreground">{author}</span>
            </p>
          )}
        </header>

        <div class="prose prose-zinc max-w-none">
          <slot />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
