---
import { getCollection } from 'astro:content';
import IndexLayout from '@/layouts/IndexLayout.astro';
import { FAQAccordion } from '@/components/ui/FAQAccordion';
import { AnimatedSection } from '@/components/ui/AnimatedSection';
import { seo } from '@/config/seo';
import { getLangFromUrl } from '@/i18n/utils';
import { normalizeId } from '@/lib/related';

const lang = getLangFromUrl(Astro.url);

const entries = await getCollection('faq', (e) => !e.data.draft && e.data.lang === 'en');

// Group by category, sorted by order field
const byCategory = entries
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .reduce<Record<string, typeof entries>>((acc, entry) => {
    const cat = entry.data.category;
    (acc[cat] ??= []).push(entry);
    return acc;
  }, {});

const categories = Object.keys(byCategory);
---

<IndexLayout
  title={seo.faq.title}
  description={seo.faq.description}
  eyebrow="FAQ"
  heroTitle="Frequently asked questions"
  heroDescription="Can't find what you're looking for? Reach out to our team."
  alternateHref="/sv/faq"
>
  <section class="mx-auto max-w-3xl px-6 py-16">
    {categories.map((category) => (
      <AnimatedSection client:visible className="mb-12">
        <h2 class="text-sm font-semibold tracking-widest uppercase text-muted-foreground mb-6">
          {category}
        </h2>
        <FAQAccordion
          client:visible
          items={byCategory[category].map((e) => ({
            q: e.data.question,
            a: e.data.answer,
          }))}
        />
        <div class="mt-4 pt-4 border-t border-border">
          {byCategory[category].map((e) => (
            <a
              href={`/faq/${normalizeId(e.id)}`}
              class="block text-xs text-muted-foreground hover:text-foreground transition-colors py-1"
            >
              {e.data.question} →
            </a>
          ))}
        </div>
      </AnimatedSection>
    ))}
  </section>
</IndexLayout>
