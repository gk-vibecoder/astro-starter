---
import { getLangFromUrl, useTranslations, getLocalePath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const lp = (path: string) => getLocalePath(lang, path);

const currentYear = new Date().getFullYear();

const footerColumns = [
  {
    title: t.footer.columns.product.title,
    links: [
      { label: t.footer.columns.product.features, href: lp('/features') },
      { label: t.footer.columns.product.integrations, href: lp('/integrations') },
      { label: t.footer.columns.product.security, href: lp('/security') },
    ],
  },
  {
    title: t.footer.columns.company.title,
    links: [
      { label: t.footer.columns.company.aboutUs, href: lp('/about-us') },
      { label: t.footer.columns.company.contact, href: lp('/contact') },
      { label: t.footer.columns.company.blog, href: lp('/blog') },
    ],
  },
  {
    title: t.footer.columns.resources.title,
    links: [
      { label: t.footer.columns.resources.faq, href: lp('/faq') },
      { label: t.footer.columns.resources.blog, href: lp('/blog') },
      { label: t.footer.columns.resources.contact, href: lp('/contact') },
    ],
  },
  {
    title: t.footer.columns.legal.title,
    links: [
      { label: t.footer.columns.legal.privacyPolicy, href: lp('/privacy-policy') },
      { label: t.footer.columns.legal.termsOfService, href: lp('/terms-of-service') },
    ],
  },
];
---

<footer class="border-t border-border">
  <div class="mx-auto max-w-6xl px-6 py-12 md:py-16">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-6">
      <!-- Brand column -->
      <div class="col-span-2">
        <a href={lp('/')} class="font-semibold text-foreground">Acme</a>
        <p class="mt-3 max-w-xs text-sm leading-relaxed text-muted-foreground">
          {t.footer.tagline}
        </p>
        <div class="mt-4 flex items-center gap-3">
          <a
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted-foreground transition-colors hover:text-foreground"
            aria-label="Acme on LinkedIn"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
              <rect width="4" height="12" x="2" y="9" />
              <circle cx="4" cy="4" r="2" />
            </svg>
          </a>
          <a
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted-foreground transition-colors hover:text-foreground"
            aria-label="Acme on X (Twitter)"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.742l7.737-8.841L1.254 2.25H8.08l4.261 5.638 5.903-5.638Zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Link columns -->
      {footerColumns.map(({ title, links }) => (
        <div>
          <p class="text-sm font-medium text-foreground">{title}</p>
          <ul class="mt-3 space-y-2">
            {links.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class="text-sm text-muted-foreground transition-colors hover:text-foreground"
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-border pt-6 sm:flex-row">
      <p class="text-sm text-muted-foreground">
        &copy; {currentYear} Acme. {t.footer.copyright}
      </p>
      <div class="flex items-center gap-4">
        <a
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-muted-foreground transition-colors hover:text-foreground"
        >
          {t.footer.changelog}
        </a>
        <a
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-muted-foreground transition-colors hover:text-foreground"
        >
          {t.footer.roadmap}
        </a>
      </div>
    </div>
  </div>
</footer>
