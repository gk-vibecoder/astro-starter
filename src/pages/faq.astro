---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/sections/PageHero.astro';
import CTA from '@/components/sections/CTA.astro';
import { seo } from '@/config/seo';

const groups = [
  {
    topic: 'Product & Features',
    items: [
      {
        q: 'What is Acme?',
        a: 'Acme is a modern platform powered by AI. Track, automate, and grow your operations in one place — across every workflow, with seamless integrations and AI-driven insights from the Aria AI Agent.',
      },
      {
        q: 'Why should I use Acme?',
        a: 'Acme gives you a structured platform to consolidate your entire stack in one place. Instead of scattered tools, you get unified data, automated workflows, real-time analytics, and the Aria AI Agent working for you 24/7.',
      },
      {
        q: 'How do I get started?',
        a: 'Sign up for early access on the Acme website — no payment information is required. Once approved, you can immediately begin connecting your tools and exploring the platform.',
      },
    ],
  },
  {
    topic: 'Integrations',
    items: [
      {
        q: 'What tools does Acme integrate with?',
        a: 'Acme integrates with 50+ popular tools including Stripe, Salesforce, HubSpot, Slack, GitHub, Zapier, and Google Workspace. We are continuously adding new integrations based on customer demand.',
      },
      {
        q: 'Does Acme have an API?',
        a: 'Yes. Acme provides a robust REST API and webhooks for custom integrations. Documentation is available in our developer portal. Enterprise customers also have access to dedicated integration support.',
      },
    ],
  },
  {
    topic: 'Aria AI',
    items: [
      {
        q: 'What is Aria AI?',
        a: 'Aria is our AI agent built into the Acme platform. It surfaces insights, automates repetitive tasks, and answers questions about your data — available 24/7 across everything you manage on Acme.',
      },
      {
        q: 'How does Aria AI learn about my business?',
        a: 'Aria is contextualized by the data you bring into Acme through integrations and manual inputs. It does not train on your data for general model use — your data stays private and is used only to serve your specific queries and automations.',
      },
    ],
  },
  {
    topic: 'Pricing',
    items: [
      {
        q: 'How does Acme pricing work?',
        a: 'Acme operates on a subscription model. We offer a free tier for early access and paid plans for teams that need advanced features, more seats, or enterprise-grade controls. Contact us for custom pricing.',
      },
      {
        q: 'Is there a free trial?',
        a: 'Yes — our early access tier is free with no payment information required. You can explore the platform, connect integrations, and use Aria AI before committing to a paid plan.',
      },
    ],
  },
  {
    topic: 'Security',
    items: [
      {
        q: 'Is my data secure with Acme?',
        a: 'Yes. Acme is SOC 2 Type II certified. All data is encrypted at rest using AES-256 and in transit using TLS 1.3. We support SSO, SAML, and 2FA for authentication, and conduct regular internal and external security audits.',
      },
      {
        q: 'Does Acme sell my data?',
        a: 'No. We do not sell your personal or business data to any third party. Our business model does not depend on data monetization, and all third-party providers we work with adhere to the same standard.',
      },
    ],
  },
  {
    topic: 'Support',
    items: [
      {
        q: 'How do I get support?',
        a: 'You can reach our support team via the in-app chat, by emailing hello@acme.com, or through our community forum. Enterprise customers have access to a dedicated account manager and priority support SLA.',
      },
    ],
  },
];
---

<BaseLayout title={seo.faq.title} description={seo.faq.description}>
  <PageHero
    label="FAQ"
    title="Frequently asked questions."
    description="Common questions about Acme and the platform. Can't find your answer? Reach out at hello@acme.com."
  />

  <section class="mx-auto max-w-6xl px-6 py-16 pb-24">
    <div class="space-y-12">
      {groups.map(({ topic, items }) => (
        <div class="grid lg:grid-cols-4 gap-6 lg:gap-12">
          <div>
            <p class="text-xs font-semibold tracking-widest uppercase text-muted-foreground pt-5">{topic}</p>
          </div>
          <div class="lg:col-span-3 divide-y divide-border border-t border-border">
            {items.map(({ q, a }) => (
              <details class="group py-5">
                <summary class="flex items-center justify-between gap-4 cursor-pointer list-none">
                  <span class="text-sm font-semibold text-foreground">{q}</span>
                  <span class="size-5 rounded-full border border-border flex items-center justify-center shrink-0 text-muted-foreground group-open:rotate-45 transition-transform duration-200">+</span>
                </summary>
                <p class="mt-4 text-sm text-muted-foreground leading-relaxed">{a}</p>
              </details>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <CTA />
</BaseLayout>
