---
import { getCollection, type CollectionEntry } from 'astro:content';
import ArticleLayout from '@/layouts/ArticleLayout.astro';
import { pickRelated } from '@/lib/related';

export async function getStaticPaths() {
  const normalizeId = (id: string) => id.replace(/(?:\.sv)?\.(md|mdx)$/, '');
  const posts = await getCollection('blog', (p) => !p.data.draft && p.data.lang === 'en');
  return posts.map((post) => ({
    params: { slug: normalizeId(post.id) },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const normalizeId = (id: string) => id.replace(/(?:\.sv)?\.(md|mdx)$/, '');
const { post } = Astro.props;
const { Content, headings } = await post.render();

const allPosts = await getCollection('blog', (p) => !p.data.draft && p.data.lang === 'en');

const relatedArticles = pickRelated(
  allPosts.map((p) => ({
    id: p.id,
    title: p.data.title,
    description: p.data.description,
    href: `/blog/${normalizeId(p.id)}`,
    category: p.data.tags?.[0],
    image: p.data.image,
    meta: p.data.pubDate.toLocaleDateString('en-GB', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    }),
  })),
  post.id,
  post.data.tags?.[0],
);

const cleanSlug = normalizeId(post.id);
---

<ArticleLayout
  title={post.data.title}
  description={post.data.description}
  date={post.data.pubDate}
  author={post.data.author}
  backHref="/blog"
  backLabel="All posts"
  image={post.data.image}
  ogImage={post.data.ogImage}
  alternateHref={`/sv/blog/${cleanSlug}`}
  headings={headings}
  relatedArticles={relatedArticles}
>
  <Content />
</ArticleLayout>
